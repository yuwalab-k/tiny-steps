<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Tiny Steps</title>
<script src="https://unpkg.com/htmx.org@1.9.3"></script>
<style>
  :root {
    --ink: #1f2a3b;
    --muted: #667085;
    --bg: #f6f5f1;
    --panel: #ffffff;
    --soft: #eef2f6;
    --mint: #cfeee4;
    --peach: #ffe1c8;
    --sky: #d9e8ff;
    --sun: #ffe9a9;
    --line: #e3e7ee;
    --accent: #3a7f6b;
    --accent-2: #e07a5f;
    --shadow: 0 12px 30px rgba(33, 50, 74, 0.08);
    --radius-lg: 22px;
    --radius-md: 14px;
    --radius-sm: 10px;
  }

  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: "Manrope", "Segoe UI", sans-serif;
    color: var(--ink);
    background: radial-gradient(circle at top left, #fff4e7 0%, var(--bg) 40%, #f0f7f5 100%);
  }

  .app {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px;
    display: grid;
    gap: 24px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-badge {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--mint), var(--sky));
    display: grid;
    place-items: center;
    box-shadow: var(--shadow);
    font-size: 20px;
  }

  .brand h1 {
    font-size: 22px;
    margin: 0;
  }

  .nav {
    display: flex;
    gap: 10px;
  }

  .nav a {
    text-decoration: none;
  }

  .nav button {
    border: 1px solid var(--line);
    background: var(--panel);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
  }

  .nav button.active {
    color: var(--ink);
    background: var(--soft);
    border-color: transparent;
  }

  .dashboard {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
  }

  .card {
    background: var(--panel);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    box-shadow: var(--shadow);
  }

  .card h2 {
    margin: 0 0 14px 0;
    font-size: 20px;
  }

  .muted { color: var(--muted); }

  .progress {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: var(--soft);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    margin-bottom: 18px;
  }

  .progress-bar {
    height: 8px;
    background: #dfe6ee;
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-bar span {
    display: block;
    height: 100%;
    width: 62%;
    background: linear-gradient(90deg, var(--accent), #55b398);
    border-radius: inherit;
  }

  .task-list {
    display: grid;
    gap: 12px;
  }

  .task {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    background: #fbfcfe;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  .task-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .checkbox {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    border: 2px solid var(--accent);
  }

  .task.done .checkbox {
    background: var(--accent);
    box-shadow: inset 0 0 0 3px #fff;
  }

  .sticker {
    width: 32px;
    height: 32px;
    border-radius: 10px;
    background: var(--sun);
    display: grid;
    place-items: center;
    font-size: 16px;
    border: none;
    cursor: pointer;
  }

  .streak {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--peach);
    border-radius: var(--radius-md);
    font-weight: 600;
  }

  .tree-preview {
    display: grid;
    gap: 14px;
  }

  .tree-node {
    border-left: 2px solid var(--line);
    padding-left: 12px;
  }

  .tree-node .node {
    background: var(--soft);
    padding: 8px 12px;
    border-radius: 12px;
    display: inline-block;
    margin-bottom: 8px;
  }

  .tree-node .leaf {
    background: #fff;
    border: 1px dashed var(--line);
    padding: 6px 10px;
    border-radius: 10px;
    margin: 4px 0 0 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .section-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .goal-tree {
    display: grid;
    gap: 16px;
  }

  .goal-card {
    padding: 14px 16px;
    background: var(--panel);
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
  }

  .goal-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .goal-branch {
    display: grid;
    gap: 8px;
    padding-left: 16px;
    border-left: 2px solid var(--line);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--mint);
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
  }

  .sticker-board {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 10px;
  }

  .sticker-tile {
    background: var(--panel);
    border-radius: 16px;
    border: 1px solid var(--line);
    height: 54px;
    display: grid;
    place-items: center;
    font-size: 20px;
  }

  .reward {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 16px;
    padding: 12px 14px;
    background: var(--soft);
    border-radius: var(--radius-md);
  }

  .reward .progress-bar {
    flex: 1;
  }

  .ai-grid {
    display: grid;
    gap: 12px;
  }

  .ai-card {
    border: 1px solid var(--line);
    background: #fbfcfe;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    display: grid;
    gap: 8px;
  }

  .ai-card button {
    justify-self: start;
    border: none;
    background: var(--mint);
    color: var(--ink);
    padding: 6px 12px;
    border-radius: 999px;
    cursor: pointer;
  }

  .log-list {
    display: grid;
    gap: 10px;
  }

  .log-item {
    padding: 10px 12px;
    border-radius: var(--radius-md);
    background: #fbfcfe;
    border: 1px solid var(--line);
  }

  .list-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .list-table th, .list-table td {
    text-align: left;
    padding: 8px 10px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }

  .filter-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 10px;
  }

  .filter-row input, .filter-row select {
    padding: 6px 8px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: #fff;
    color: var(--ink);
  }

  select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, var(--muted) 50%), linear-gradient(135deg, var(--muted) 50%, transparent 50%);
    background-position: calc(100% - 14px) 50%, calc(100% - 8px) 50%;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 28px;
  }

  .filter-actions {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  .progress-list {
    display: grid;
    gap: 10px;
  }

  @media (max-width: 980px) {
    .dashboard, .section-grid { grid-template-columns: 1fr; }
    .goal-row { grid-template-columns: 1fr; }
    .sticker-board { grid-template-columns: repeat(4, 1fr); }
  }
</style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <div class="brand">
        <div class="brand-badge">★</div>
        <div>
          <h1>Goal Tree</h1>
          <div class="muted">今日の一歩を、積み上げる。</div>
        </div>
      </div>
      <div class="nav">
        <a href="#today"><button class="active">今日のやること</button></a>
        <a href="#goal-tree"><button>目標ツリー</button></a>
        <a href="#stickers"><button>シール帳</button></a>
        <a href="#ai"><button>AI相談</button></a>
        <a href="#lists"><button>一覧</button></a>
        <a href="#logs"><button>ログ</button></a>
        <a href="#progress"><button>達成度</button></a>
      </div>
    </div>

    <section class="dashboard" id="today">
      <div class="card">
        <h2>今日のやること</h2>
        <div class="progress">
          <div>
            <div class="muted">本日の進捗（<%= stash('today') %>）</div>
            <strong><%= stash('stats')->{done} %> / <%= stash('stats')->{total} %> 完了</strong>
          </div>
          <div style="flex:1">
            <div class="progress-bar"><span style="width: <%= stash('stats')->{progress_pct} %>%;"></span></div>
          </div>
          <div class="streak">🔥 <%= stash('stats')->{streak} %>日連続</div>
        </div>
        <%== include 'partials/task_list', tasks => stash('tasks') %>
      </div>

      <div class="card">
        <h2>目標ツリー（ミニ）</h2>
        <div class="tree-preview">
          <%== include 'partials/goal_tree', nodes => stash('goal_tree'), level => 0 %>
        </div>
        <div style="margin-top: 16px;" class="badge">⭐ 今日は <%= stash('stats')->{done} %> ステップ前進</div>
      </div>
    </section>

    <section class="section-grid" id="goal-tree">
      <div class="card">
        <h2>目標ツリー</h2>
        <%== include 'partials/goal_tree_cards_wrapper', goal_tree => stash('goal_tree') %>
      </div>

      <div class="card" id="stickers">
        <h2>シール帳</h2>
        <div class="muted">今週の達成シール</div>
        <div class="sticker-board" style="margin-top: 14px;">
% for my $s (@{ stash('stickers')->{stickers} || [] }) {
          <div class="sticker-tile"><%= $s->{digital_obtained} ? '⭐' : '☆' %></div>
% }
        </div>
        <div class="reward">
          <div>
            <div class="muted">合計ポイント</div>
            <strong><%= stash('stickers')->{total_points} %> ポイント</strong>
          </div>
          <div class="progress-bar"><span style="width: 40%;"></span></div>
          <div class="sticker">🏅</div>
        </div>
        <div class="muted" style="margin-top: 10px;">連続 <%= stash('stickers')->{consecutive_days} %>日</div>
      </div>
    </section>

    <section class="section-grid" id="ai">
      <div class="card">
        <h2>AIタスク相談</h2>
        <div class="log-item" style="margin-bottom: 12px;">
          <strong>大目標入力</strong>
          <form method="post" action="/goals" style="margin-top: 6px; display: grid; gap: 8px;">
            <input type="text" name="title" placeholder="例: 宇宙飛行士になる" required>
            <input type="date" name="deadline">
            <button type="submit">大目標を追加</button>
          </form>
        </div>

        <div class="log-item" style="margin-bottom: 12px;">
          <strong>AIが提案する小目標</strong>
          <form method="post" action="/ai/suggest" hx-post="/ai/suggest" hx-target="#ai-suggestions" hx-swap="outerHTML" style="margin-top: 6px; display: grid; gap: 8px;">
            <input type="text" name="prompt" placeholder="例: 英語力向上 / 体力管理 / 科学知識">
            <button type="submit">AI提案を取得</button>
          </form>
          <div class="muted" style="margin-top: 6px;">選択した小目標は「タスク化」または「小目標追加」ができます。</div>
        </div>

        <div class="log-item" style="margin-bottom: 12px;">
          <strong>追加先を選択</strong>
          <form style="margin-top: 6px; display: grid; gap: 8px;">
            <select id="goal-select">
% for my $opt (@{ stash('goal_options') || [] }) {
              <option value="<%= $opt->{id} %>"><%= $opt->{label} %></option>
% }
            </select>
            <div class="muted">AI提案の追加先として使います。</div>
          </form>
        </div>

        <div id="ai-suggestions">
          <%== include 'partials/ai_suggestions', ai_suggestions => stash('ai_suggestions'), selected_goal_id => stash('goal_options')->[0]{id} %>
        </div>
      </div>

      <div class="card">
        <h2>物理シール管理</h2>
        <div class="log-list">
% for my $s (@{ stash('stickers')->{stickers} || [] }) {
          <div class="log-item">
            <strong><%= $s->{task} %></strong>
            <div class="muted">デジタル: <%= $s->{digital_obtained} ? '獲得' : '未獲得' %> / 物理: <%= $s->{physical_obtained} ? '取得済' : '未取得' %> / 親チェック: <%= $s->{parent_checked} ? '済' : '未' %></div>
            <div style="margin-top: 6px; display: flex; gap: 8px;">
              <form method="post" action="/stickers/<%= $s->{task_id} %>/physical">
                <button type="submit" <%= $s->{physical_obtained} ? 'disabled' : '' %>>物理シール取得</button>
              </form>
              <form method="post" action="/stickers/<%= $s->{task_id} %>/parent">
                <button type="submit" <%= $s->{parent_checked} ? 'disabled' : '' %>>親チェック済み</button>
              </form>
            </div>
          </div>
% }
        </div>
      </div>
    </section>

    <section class="section-grid" id="progress">
      <div class="card">
        <h2>目標達成度</h2>
        <div class="progress-list">
% my $root = stash('goal_tree')->[0];
% if ($root) {
          <div class="log-item">
            <strong><%= $root->{title} %></strong>
            <div class="muted">進捗 <%= $root->{progress} %>%</div>
            <div class="progress-bar" style="margin-top: 8px;"><span style="width: <%= $root->{progress} %>%;"></span></div>
          </div>
%   for my $sub (@{ $root->{children} || [] }) {
          <div class="log-item">
            <strong><%= $sub->{title} %></strong>
            <div class="muted">進捗 <%= $sub->{progress} %>%</div>
            <div class="progress-bar" style="margin-top: 8px;"><span style="width: <%= $sub->{progress} %>%;"></span></div>
          </div>
%   }
% } else {
          <div class="log-item">目標がまだありません。</div>
% }
        </div>
      </div>
    </section>

    <section class="section-grid" id="lists">
      <div class="card">
        <h2>目標一覧・検索</h2>
        <form hx-get="/partials/goal_list" hx-target="#goal-list" hx-swap="outerHTML">
          <div class="filter-row">
            <input type="text" name="q" placeholder="目標名で検索">
            <select name="sort">
              <option value="title">名前</option>
              <option value="deadline">期限</option>
              <option value="created_at">作成日</option>
              <option value="updated_at">更新日</option>
            </select>
            <select name="dir">
              <option value="asc">昇順</option>
              <option value="desc">降順</option>
            </select>
          </div>
          <div class="filter-actions">
            <button type="submit">検索</button>
          </div>
        </form>
        <%== include 'partials/goal_list', goal_list => stash('goal_list') %>
      </div>

      <div class="card">
        <h2>タスク一覧・検索</h2>
        <form hx-get="/partials/task_list_table" hx-target="#task-list-table" hx-swap="outerHTML">
          <div class="filter-row">
            <input type="text" name="q" placeholder="タスク名で検索">
            <select name="priority">
              <option value="all">優先度: すべて</option>
              <option value="high">高</option>
              <option value="medium">中</option>
              <option value="low">低</option>
            </select>
            <select name="repeat">
              <option value="all">繰り返し: すべて</option>
              <option value="none">単発</option>
              <option value="daily">毎日</option>
              <option value="weekly">毎週</option>
            </select>
          </div>
          <div class="filter-row">
            <select name="sort">
              <option value="created_at">作成日</option>
              <option value="updated_at">更新日</option>
              <option value="title">名前</option>
              <option value="priority">優先度</option>
              <option value="duration_min">所要時間</option>
            </select>
            <select name="dir">
              <option value="desc">降順</option>
              <option value="asc">昇順</option>
            </select>
            <label class="muted" style="display:flex; align-items:center; gap:6px;">
              <input type="checkbox" name="include_archived" value="1"> アーカイブ含む
            </label>
          </div>
          <div class="filter-actions">
            <button type="submit">検索</button>
          </div>
        </form>
        <%== include 'partials/task_list_table', task_list => stash('task_list') %>
      </div>
    </section>

    <section class="section-grid" id="logs">
      <div class="card">
        <h2>ログフィルタ</h2>
        <form hx-get="/logs/filter" hx-target="#logs-filtered" hx-swap="outerHTML">
          <div class="filter-row">
            <input type="date" name="from">
            <input type="date" name="to">
            <select name="type">
              <option value="all">すべて</option>
              <option value="task_done">タスク完了</option>
              <option value="task_undone">タスク未完了</option>
              <option value="goal_created">目標作成</option>
              <option value="goal_updated">目標更新</option>
              <option value="goal_archived">目標アーカイブ</option>
              <option value="task_created">タスク作成</option>
              <option value="task_updated">タスク更新</option>
              <option value="task_archived">タスクアーカイブ</option>
              <option value="ai_task_added">AIタスク追加</option>
              <option value="physical_obtained">物理シール取得</option>
              <option value="parent_checked">親チェック</option>
            </select>
          </div>
          <div class="filter-actions">
            <button type="submit">フィルタ</button>
          </div>
        </form>
        <%== include 'partials/logs_filtered', logs_filtered => stash('logs_filtered') %>
      </div>
      <div class="card">
        <h2>ログ（直近）</h2>
        <div class="log-list">
% for my $log (@{ stash('logs') || [] }) {
          <div class="log-item">
            <strong><%= $log->{action} %></strong>
            <div class="muted"><%= $log->{task} // '' %></div>
            <div class="muted"><%= $log->{timestamp} %></div>
          </div>
% }
        </div>
      </div>
    </section>
  </div>
  <script>
    function updateGoalActions() {
      const select = document.getElementById('goal-select');
      if (!select) return;
      const goalId = select.value || '1';
      document.querySelectorAll('form[data-goal-action]').forEach(form => {
        const action = form.getAttribute('data-goal-action');
        const url = `/goals/${goalId}/${action}`;
        form.setAttribute('action', url);
        form.setAttribute('hx-post', url);
      });
    }

    document.addEventListener('change', (e) => {
      if (e.target && e.target.id === 'goal-select') {
        updateGoalActions();
      }
    });

    document.addEventListener('htmx:afterSwap', (e) => {
      if (e.target && e.target.id === 'ai-suggestions') {
        updateGoalActions();
      }
    });

    updateGoalActions();
  </script>
</body>
</html>
