% my $tasks = stash('tasks') || [];
<div class="task-list" id="task-list">
% if (@$tasks) {
%   for my $task (@$tasks) {
%     stash(task => $task);
%= include 'partials/task'
%   }
% } else {
  <div class="task" style="justify-content: center;">
    <div class="muted">今日のタスクはまだありません。</div>
  </div>
% }
</div>
