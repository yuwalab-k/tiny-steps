% my $nodes = stash('nodes') || [];
% my $level = stash('level') // 0;
% for my $node (@$nodes) {
  <div class="tree-node" style="margin-left: <%= $level * 8 %>px;">
    <div class="node"><%= $node->{title} %></div>
%   for my $task (@{ $node->{tasks} || [] }) {
    <div class="leaf"><span>□</span> <%= $task->{title} %></div>
%   }
%   if (@{ $node->{children} || [] }) {
%     stash(nodes => $node->{children}, level => $level + 1);
%= include 'partials/goal_tree'
%   }
  </div>
% }
